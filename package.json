{
  "name": "puescofest",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/check-netlify-turnstile-env.js",
    "dev": "next dev",
    "dev:tina": "npx @tinacms/cli dev -c \"next dev\"",
    "build": "next build --webpack",
    "build:tina": "npx @tinacms/cli build && next build --webpack",
    "copy-function-deps": "mkdir -p netlify/functions/node_modules && cp -r node_modules/resend netlify/functions/node_modules/",
    "postbuild": "copyfiles -u 4 node_modules/tw-elements/dist/js/tw-elements.umd.min.* public/js",
    "postinstall": "node postinstall.js",
    "start": "next start",
    "start:tina": "npx @tinacms/cli build && next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "tina:schema": "npx @tinacms/cli dev --no-server"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "encrypted-env": "^0.2.1",
    "formdata-node": "^6.0.3",
    "next": "^16.2.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.76.1",
    "react-markdown": "^9.1.0",
    "resend": "^6.12.4",
    "tinacms": "^3.8.3",
    "tw-elements": "1.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tinacms/cli": "^2.4.1",
    "@types/node": "22.15.21",
    "autoprefixer": "^10.5.0",
    "babel-plugin-styled-components": "^2.3.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
